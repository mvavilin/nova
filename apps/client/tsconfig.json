{
  "extends": "../../packages/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2021",
    "types": ["vite/client"],
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@api/*": ["api/*"],
      "@app/*": ["app/*"],
      "@ComponentsAPI": ["api/ComponentsAPI/index.ts"],
      "@ComponentsAPI/*": ["api/ComponentsAPI/*"],
      "@components": ["components"],
      "@components/*": ["components/*"],
      "@constants": ["constants"],
      "@constants/*": ["constants/*"],
      "@pages/*": ["pages/*"],
      "@pages": ["pages"],
      "@router/*": ["router/*"],
      "@utils": ["utils"],
      "@types": ["types"],
      "@types/*": ["types/*"],
      "@state/*": ["state/*"],
      "@state": ["state"],
      "@store/*": ["store/*"],
      "@store": ["store"],
      "@utils/*": ["utils/*"],
      "@assets/*": ["assets/*"],
      "@__mocks__/*": ["__mocks__/*"],
      "@__mocks__": ["__mocks__"],
      "@styles": ["constants/styles"],
      "@app": ["main"],
      "@shared/*": ["../../../packages/shared/src/*"]
    }
  },
  "include": ["src", "vite.config.ts", "vitest.config.ts", "tailwind.config.ts"]
}
