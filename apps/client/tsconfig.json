{
  "extends": "../../packages/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2021",
    "types": ["vite/client"],
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@actions": ["store/actions"],
      "@actions/*": ["store/actions/*"],
      "@afterwares": ["store/afterwares"],
      "@afterwares/*": ["store/afterwares/*"],
      "@AppActions": ["store/types/action"],
      "@api/*": ["api/*"],
      "@app": ["main"],
      "@app/*": ["app/*"],
      "@ComponentsAPI": ["api/ComponentsAPI/index.ts"],
      "@ComponentsAPI/*": ["api/ComponentsAPI/*"],
      "@components": ["components"],
      "@components/*": ["components/*"],
      "@constants": ["constants"],
      "@constants/*": ["constants/*"],
      "@initialState": ["store/initialState.ts"],
      "@middlewares": ["store/middlewares"],
      "@middlewares/*": ["store/middlewares/*"],
      "@pages": ["pages"],
      "@pages/*": ["pages/*"],
      "@reducers": ["store/reducers"],
      "@reducers/*": ["store/reducers/*"],
      "@RouterAPI/*": ["api/RouterAPI/*"],
      "@router": ["main"],
      "@shared/*": ["../../../packages/shared/src/*"],
      "@SocketClientAPI": ["api/SocketClientAPI"],
      "@SocketClientAPI/*": ["api/SocketClientAPI/*"],
      "@State": ["store/types/state.ts"],
      "@StateAPI": ["api/StateAPI"],
      "@store": ["store/store.ts"],
      "@store/*": ["store/*"],
      "@styles": ["constants/styles"],
      "@types": ["types"],
      "@types/*": ["types/*"],
      "@utils": ["utils"],
      "@utils/*": ["utils/*"],
      "@__mocks__": ["__mocks__"],
      "@__mocks__/*": ["__mocks__/*"],
      "@assets/*": ["assets/*"],
      "@i18n": ["i18n"],
      "@i18n/*": ["i18n/*"]
    }
  },
  "include": ["src", "vite.config.ts", "vitest.config.ts", "tailwind.config.ts"]
}
